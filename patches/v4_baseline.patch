+// Advanced experiment (Phase 1): load cache list from a text file.
+// Format: first line is total count, followed by count lines, one uint32 per line.
+template <typename T, typename LabelT> void PQFlashIndex<T, LabelT>::load_cache_list(const std::string &file_path)
+{
+    std::ifstream ifs(file_path);
+    if (!ifs.is_open())
+    {
+        diskann::cerr << "ERROR: load_cache_list: cannot open file: " << file_path << std::endl;
+        std::exit(-1);
+    }
+    size_t n = 0;
+    ifs >> n;
+    std::vector<uint32_t> list;
+    list.reserve(n);
+    for (size_t i = 0; i < n; i++)
+    {
+        uint32_t nid;
+        if (!(ifs >> nid))
+        {
+            diskann::cerr << "ERROR: load_cache_list: file truncated at i=" << i << " (expected " << n << " ids)" << std::endl;
+            std::exit(-1);
+        }
+        list.push_back(nid);
+    }
+    ifs.close();
+    diskann::cout << "load_cache_list(file): read " << list.size() << " node ids from " << file_path << std::endl;
+    this->load_cache_list(list);
+}
+
+// Advanced experiment (Phase 1): enable per-query trace file.
+// Format: "qid event node_id" per line, event in {hit, miss, read}.
+template <typename T, typename LabelT> void PQFlashIndex<T, LabelT>::set_trace(const std::string &file_path)
+{
+    if (_trace_ofs.is_open())
+    {
+        _trace_ofs.close();
+    }
+    _trace_ofs.open(file_path, std::ios::out | std::ios::trunc);
+    if (!_trace_ofs.is_open())
+    {
+        diskann::cerr << "ERROR: set_trace: cannot open file: " << file_path << std::endl;
+        _trace_enabled = false;
+        return;
+    }
+    _trace_enabled = true;
+    _trace_current_qid = -1;
+    diskann::cout << "Trace enabled, writing to: " << file_path << std::endl;
+}
+
+// Advanced experiment (Phase 1): set the current query id (called by search driver right before cached_beam_search).
+template <typename T, typename LabelT> void PQFlashIndex<T, LabelT>::set_trace_qid(int qid)
+{
+    _trace_current_qid = qid;
+}
+
+// Advanced experiment (Phase 1): internal helper, write one "qid event nid" line (thread-safe via omp critical).
+template <typename T, typename LabelT> inline void PQFlashIndex<T, LabelT>::trace_write(const char *event, uint32_t nid)
+{
+    if (!_trace_enabled || !_trace_ofs.is_open() || _trace_current_qid < 0)
+        return;
+#pragma omp critical(trace_write)
+{
+    _trace_ofs << _trace_current_qid << ' ' << event << ' ' << nid << '\n';
+}
+}
+
+// Real 4KB block reorder (round 2 phase 1): load permutation map.
+// perm.bin format: N x uint32 little-endian; perm[i] = new DATA sector index for node i.
+// (File sector 0 is the header, so get_node_sector returns 1 + perm[i].)
+template <typename T, typename LabelT> void PQFlashIndex<T, LabelT>::set_perm_map(const std::string &perm_path)
+{
+    if (perm_path.empty())
+    {
+        _use_perm_map = false;
+        _perm_sector.clear();
+        return;
+    }
+    std::ifstream ifs(perm_path, std::ios::binary);
+    if (!ifs.is_open())
+    {
+        diskann::cerr << "ERROR: set_perm_map: cannot open: " << perm_path << std::endl;
+        _use_perm_map = false;
+        return;
+    }
+    // read entire file as bytes
+    std::string buf((std::istreambuf_iterator<char>(ifs)),
+                    std::istreambuf_iterator<char>());
+    if (buf.size() % 4 != 0)
+    {
+        diskann::cerr << "ERROR: set_perm_map: file size " << buf.size() << " not multiple of 4" << std::endl;
+        _use_perm_map = false;
+        return;
+    }
+    _perm_sector.resize(buf.size() / 4);
+    std::memcpy(_perm_sector.data(), buf.data(), buf.size());
+    _use_perm_map = !_perm_sector.empty();
+    diskann::cout << "Permutation map loaded: " << _perm_sector.size()
+                  << " entries (round 2 phase 1, real 4KB block reorder)" << std::endl;
+}
